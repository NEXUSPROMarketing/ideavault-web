# Supabase — these two values are client-safe by design:
# the publishable key only grants what Row Level Security allows
# (public read on content tables; user tables are owner-only).
NEXT_PUBLIC_SUPABASE_URL=https://lovhwgzagahkeronvqhx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_b-7MXUNGKgHDNPQ4s_pcFg_w6Smj6xh

# Optional: canonical site URL used for sitemap + OG metadata + email links.
# Falls back to VERCEL_URL on Vercel, then http://localhost:3000.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ---- Server-side secrets (set in Vercel env ONLY — never commit real values) ----
# Supabase → Settings → API → secret key. Used by the daily-drop cron + unsubscribe.
# SUPABASE_SECRET_KEY=sb_secret_xxx
# Resend → API Keys. Used to send the daily drop email.
# RESEND_API_KEY=re_xxx
# Optional verified sender; defaults to Resend's test sender (delivers to your own inbox only).
# RESEND_FROM="IdeaVault <drop@your-domain.com>"
# Long random string; Vercel Cron sends it as a Bearer token to /api/cron/daily-drop.
# CRON_SECRET=generate-a-long-random-string

# ---- Phase C: AI + billing (Vercel env ONLY) ----
# Build packs are generated OUTSIDE the app by the IdeaVault Pack Foreman
# agent (Hyperagent), which writes them into the build_packs table — no AI
# key is needed in the app for packs.
# On-demand generation: the Pack Foreman's webhook invocation URL (agent →
# Invocations → Webhook). Without it, packs arrive via the agent's daily run.
# PACK_FOREMAN_WEBHOOK_URL=https://...
# The webhook's secret/token (shown alongside the URL in the webhook config).
# Sent as Authorization: Bearer + X-Webhook-Secret + X-API-Key.
# PACK_FOREMAN_WEBHOOK_SECRET=...
# Pack paywall switch (off while testing; set true + redeploy to reinstate):
# PACKS_REQUIRE_PRO=true
# OPTIONAL — research chat only (chat stays dormant until this is set):
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-5
# CHAT_DAILY_LIMIT=50
# Stripe → Developers → API keys (use test keys first!).
# STRIPE_SECRET_KEY=sk_test_xxx
# Stripe → Developers → Webhooks → your endpoint → signing secret.
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe → Product catalogue → your Pro product → price IDs.
# STRIPE_PRICE_MONTHLY=price_xxx
# STRIPE_PRICE_YEARLY=price_xxx
